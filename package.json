{
  "name": "onboarding-sample-app",
  "version": "1.0.0",
  "description": "Agentic Elephant Carpaccio - Customer Onboarding Training Exercise",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm start",
    "client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "cd server && npm test",
    "test:e2e": "npx playwright test",
    "prepare": "husky"
  },
  "lint-staged": {
    "client/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "server/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.40.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.6"
  }
}
